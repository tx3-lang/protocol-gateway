# -----------------------------------------------------------
# PARTIES
# -----------------------------------------------------------
# User              — trader/creator wallet (provided per call).
# OrderScript       — order validator + user stake (provided per call).
# BondingCurveScript — fixed script+script address where pool UTxOs live.
# MetadataScript    — fixed validator that stores token metadata.
# FeeAddress        — snek.fun launch-fee collector.

BONDINGCURVESCRIPT=addr1xxg94wrfjcdsjncmsxtj0r87zk69e0jfl28n934sznu95tdj764lvrxdayh2ux30fl0ktuh27csgmpevdu89jlxppvrs2993lw
METADATASCRIPT=addr1q8lsjfvtpnu9kv5zhwgsdcw03tlkuwcvjqmzm35arx9xl6k6s0uhca7762y56q2j9en5ttn69p7a048cw3mz62fuj3mqauv0x3
FEEADDRESS=addr1qy32agk6zhjffcqhvu296j9a594k6smlr3zfsgaqgsvnmtefn2pw7433r2ss4hcycqrj6jrsaw056hlnz5fjgdyyrd6qsw8ngt

# -----------------------------------------------------------
# ENV — stable values
# -----------------------------------------------------------

# Reference UTxO holding the order validator plutusV2 script (hash
# d9143ac63473b17a215d1b7484dfb6ac6b4a0005beb0e26a6ca02c96).
ORDER_VALIDATOR_REF="e2ed9e953ebf98ca701fc93588d73cb9769f87b9d13712474f566a0743963e8b#0"

# Permitted executor (snek.fun batcher) PKH — recorded in every order datum.
PERMITTED_EXECUTOR=e865941988edcca559268b57b7ee939974fd42fd26c7e1acd7a50678

# Minimum ADA the batcher returns to the user when the order is filled.
MIN_ORDER_OUT_ADA=1100000

# Fixed batcher tip kept inside the order UTxO.
EXECUTOR_FEE=1500000

# Fixed ADA escrow for sell orders = EXECUTOR_FEE + MIN_ORDER_OUT_ADA.
SELL_ESCROW_ADA=2600000

# Factory witness PKH — present in every pool datum (field 7).
FACTORY_WITNESS=8807fbe6e36b1c35ad6f36f0993e2fc67ab6f2db06041cfa3a53c04a

# Stable pool beacon NFT minting policy.

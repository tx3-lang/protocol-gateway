@startuml c4-container
!include <C4/C4_Container>

LAYOUT_WITH_LEGEND()

title Container Diagram — Tx3 Protocol API Layer

Person_Ext(client, "Client", "dApp or signing wallet")
System_Ext(trp, "TRP Service", "Converts TIR + args to unsigned CBOR hex")

System_Boundary(api, "Tx3 Protocol API Layer") {
    Container(server, "HTTP Server", "axum / Rust", "Accepts JSON-RPC 2.0 requests.\nParses protocol.tx method and dispatches to handler.")
    Container(registry, "TII Registry", "In-memory / Rust", "Loads *.tii files from disk at startup.\nExposes protocol and transaction lookup.")
    Container(trpClient, "TRP Client", "reqwest / Rust", "Sends TIR content and resolved args\nto TRP Service. Returns CBOR hex.")
    ContainerDb(protocols, "Protocol Files", "File system — ./protocols/", "One *.tii file per supported Tx3 protocol,\ngenerated by trix build.")
}

Rel(client, server, "protocol.tx", "JSON-RPC / HTTP POST")
Rel(server, registry, "lookup protocol + transaction")
Rel(registry, protocols, "scan and read at startup", "file I/O")
Rel(server, trpClient, "forward TIR + args")
Rel(trpClient, trp, "resolve transaction", "HTTP POST / JSON")

@enduml
